{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",

    "moduleResolution": "bundler",

    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"]
}